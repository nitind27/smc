# MySQL connection (required for dynamic data)
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/SMC_DB"

# --- Vercel deployment ---
# Add DATABASE_URL in Vercel: Project → Settings → Environment Variables.
# Use the same MySQL URL. Enable for Production, Preview, and Development.
# Build will succeed without it (dummy URL is used for prisma generate), but the
# app will only work at runtime if DATABASE_URL is set to your real database.

# Optional: override API base URL (default: /api)
# NEXT_PUBLIC_API_URL=https://api.example.com

# --- OTP via SMTP (email) ---
# Used by /api/otp/send to email the OTP to the user.
# If you don't set these in production, OTP sending will fail.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-email-app-password"
SMTP_FROM="your-email@gmail.com"

# --- OTP via SMS (phone) using Twilio ---
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
SMS_FROM="+1234567890"

# Used when a user enters a 10-digit local number (example: 9876543210).
# Set to the correct country code for your users.
SMS_DEFAULT_COUNTRY_CODE="+91"
